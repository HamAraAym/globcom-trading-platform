generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// ENUMS (ROLES, STATUSES, CRM)
// ==============================
enum Role {
  BUYER_REP
  SUPPLIER_REP
  TRADING_REP
  ADMIN
  MANAGEMENT
}

enum OnlineStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum DealStatus {
  DRAFT
  ACTIVE
  UNDER_NEGOTIATION
  SENT_TO_BUYER
  CLOSED_WON
  CLOSED_LOST
  CANCELLED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ⚡ Kanban-style columns
enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskType {
  TASK
  MEETING
  ISSUE
  FEATURE
}

enum DocumentType {
  SCO        // Soft Corporate Offer
  FCO        // Full Corporate Offer
  LOI        // Letter of Interest
  CONTRACT
  OTHER
}

enum ClientType {
  CORPORATE
  INDIVIDUAL
}

// ==============================
// 1. USER & CRM MODELS
// ==============================
model User {
  id              String       @id @default(cuid())
  firstName       String
  lastName        String
  email           String       @unique
  password        String       
  role            Role         @default(BUYER_REP)
  
  // Enterprise User Management & Permissions
  isActive        Boolean      @default(true) 
  
  // Trading Permissions
  canAddDeals     Boolean      @default(true) 
  canEditDeals    Boolean      @default(true) 
  canNegotiate    Boolean      @default(true) 

  // Task Management Granular Permissions
  canCreateTasks  Boolean      @default(true)
  canEditTasks    Boolean      @default(true)
  canDeleteTasks  Boolean      @default(false)

  // ⚡ NEW: Native Device Tokens for iOS/Android Push Notifications
  pushTokens      String[]

  onlineStatus    OnlineStatus @default(OFFLINE)
  lastSeen        DateTime     @default(now())
  
// Relations
  demands         Demand[]
  supplies        Supply[]
  messages        Message[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  
  // CRM Relations
  assignedClients Client[]         
  clientActivities ClientActivity[] 
  
  // ⚡ NEW: Slack-Style Internal Comms
  channels         TeamChannel[] @relation("ChannelMembers")
  sentTeamMessages TeamMessage[] @relation("MessageSender")
  
  // Many-to-Many Task Assignments
  assignedTasks   Task[]       @relation("TaskAssignees")
  createdTasks    Task[]       @relation("TaskCreator")

  // Task Management Enhancements
  taskComments    TaskComment[]
  taskAttachments TaskAttachment[]

  documents       Document[]       

  lastActive      DateTime     @default(now())
  createdAt       DateTime     @default(now())
}

model Invitation {
  id        String   @id @default(cuid())
  email     String   @unique
  role      Role     
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Client {
  id                String     @id @default(cuid())
  type              ClientType @default(CORPORATE) 
  
  name              String     
  email             String     @unique
  phone             String?
  address           String?
  country           String?    
  notes             String?
  
  company           String?    
  registrationNo    String?    
  website           String?
  
  kycStatus         KycStatus  @default(PENDING)
  tradeLicenseUrl   String?    
  passportUrl       String?    
  proofOfFundsUrl   String?    
  bankReferenceUrl  String?    
  companyProfileUrl String?    

  assignedRepId     String?
  assignedRep       User?      @relation(fields: [assignedRepId], references: [id])

  activities        ClientActivity[]
  tasks             Task[]
  documents         Document[]

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model ClientActivity {
  id          String   @id @default(cuid())
  type        String   
  description String
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}

// ⚡ COMPLETELY REWRITTEN: Jira-Style Task Model
model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  dueDate        DateTime?  
  priority       String     @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status         TaskStatus @default(TODO)
  type           TaskType   @default(TASK)
  
  // ⚡ NEW: Recurring Task Engine Fields
  isRecurring    Boolean    @default(false)
  cronExpression String?    // e.g., "0 9 1 * *" for the 1st of every month
  nextRunAt      DateTime?

  // Jira-style Time Tracking & Tags
  estimatedHours Float?
  actualHours    Float      @default(0)
  tags           String[]
  
  // Optional Link to CRM (If it's a client task)
  clientId       String?
  client         Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Multiple Users can be assigned to one ticket
  assignees      User[]     @relation("TaskAssignees")
  
  // Audit Trail
  creatorId      String
  createdBy      User       @relation("TaskCreator", fields: [creatorId], references: [id])

  // Advanced Task Features
  comments       TaskComment[]
  subtasks       Subtask[]
  attachments    TaskAttachment[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// NEW: Subtasks for Checklists
model Subtask {
  id        String   @id @default(cuid())
  title     String
  isDone    Boolean  @default(false)
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

// NEW: Comments & Activity Feed
model TaskComment {
  id        String   @id @default(cuid())
  text      String
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  createdAt DateTime @default(now())
}

// NEW: File Attachments (KYC, PDFs, Screenshots)
model TaskAttachment {
  id           String   @id @default(cuid())
  fileName     String
  fileUrl      String
  
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  
  createdAt    DateTime @default(now())
}

model Document {
  id            String       @id @default(cuid())
  title         String
  type          DocumentType
  fileUrl       String       
  
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  generatedById String
  generatedBy   User         @relation(fields: [generatedById], references: [id])

  demandId      String?
  demand        Demand?      @relation(fields: [demandId], references: [id])
  
  supplyId      String?
  supply        Supply?      @relation(fields: [supplyId], references: [id])

  createdAt     DateTime     @default(now())
}

// ==============================
// 2. INTERNAL MARKETPLACE 
// ==============================
model Demand {
  id           String     @id @default(cuid())
  title        String
  quantity     Float      
  quantityUnit String     @default("MT") 
  tolerance    String?    
  targetPrice  Float?     
  timeline     String
  
  origin       String?
  destination  String?
  incoterms    String?
  paymentTerms String?
  inspection   String?
  packaging    String?
  insurance    String?    
  loadPort     String?    

  keyTerms     Json?      

  specs        String     
  attachments  String[]   
  status       DealStatus @default(ACTIVE)

  creatorId    String
  createdBy    User       @relation(fields: [creatorId], references: [id])
  
  chatRoom     ChatRoom?  
  documents    Document[] 

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Supply {
  id           String     @id @default(cuid())
  title        String
  quantity     Float      
  quantityUnit String     @default("MT") 
  tolerance    String?    
  price        Float?     
  location     String
  
  origin       String?
  destination  String?
  incoterms    String?
  paymentTerms String?
  inspection   String?
  packaging    String?
  insurance    String?    
  loadPort     String?    
  validityDate DateTime?  

  keyTerms     Json?      

  specs        String
  attachments  String[]   
  status       DealStatus @default(ACTIVE)

  creatorId    String
  createdBy    User       @relation(fields: [creatorId], references: [id])

  chatRoom     ChatRoom?
  documents    Document[] 

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ==============================
// 3. COLLABORATION ENGINE
// ==============================
model ChatRoom {
  id        String    @id @default(cuid())
  
  demandId  String?   @unique
  demand    Demand?   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  
  supplyId  String?   @unique
  supply    Supply?   @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id          String   @id @default(cuid())
  content     String
  attachments String[] 
  mentions    String[] 

  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])

  chatRoomId  String
  chatRoom    ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

// ==============================
// 4. GOVERNANCE & AUDIT
// ==============================
model AuditLog {
  id        String   @id @default(cuid())
  action    String   
  details   String   
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   
  message   String
  link      String?  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ==============================
// 5. SYSTEM CONFIGURATION
// ==============================
model SystemSettings {
  id              String   @id @default("global")
  companyName     String   @default("GlobCom International FZE")
  companyLogoUrl  String?  
  letterheadUrl   String?  
  updatedAt       DateTime @updatedAt
}

// ==============================
// 6. INTERNAL TEAM COMMS (SLACK/WHATSAPP STYLE)
// ==============================
model TeamChannel {
  id          String        @id @default(cuid())
  name        String?       // E.g., "Marketing Team" (Null for 1-on-1 DMs)
  isGroup     Boolean       @default(false)

  members     User[]        @relation("ChannelMembers")
  messages    TeamMessage[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TeamMessage {
  id          String        @id @default(cuid())
  content     String?       // Optional because a message might JUST be a file attachment
  
  // ⚡ Vercel Blob File Attachments
  fileUrl     String?
  fileName    String?
  fileType    String?       // e.g., "IMAGE", "PDF", "DOCUMENT"

  senderId    String
  sender      User          @relation("MessageSender", fields: [senderId], references: [id])

  channelId   String
  channel     TeamChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
}