generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// ENUMS (ROLES, STATUSES, CRM)
// ==============================
enum Role {
  BUYER_REP
  SUPPLIER_REP
  TRADING_REP
  ADMIN
  MANAGEMENT
}

enum OnlineStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum DealStatus {
  DRAFT
  ACTIVE
  UNDER_NEGOTIATION
  SENT_TO_BUYER
  CLOSED_WON
  CLOSED_LOST
  CANCELLED
}

// --- NEW CRM ENUMS ---
enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum DocumentType {
  SCO        // Soft Corporate Offer
  FCO        // Full Corporate Offer
  LOI        // Letter of Interest
  CONTRACT
  OTHER
}

// NEW: Dual-Entity Support
enum ClientType {
  CORPORATE
  INDIVIDUAL
}

// ==============================
// 1. USER & CRM MODELS
// ==============================
model User {
  id              String       @id @default(cuid())
  firstName       String
  lastName        String
  email           String       @unique
  password        String       
  role            Role         @default(BUYER_REP)
  onlineStatus    OnlineStatus @default(OFFLINE)
  lastSeen        DateTime     @default(now())
  
  // NEW: Enterprise Branding
  letterheadUrl   String?      // Supabase URL for official document header

  // Relations
  demands         Demand[]
  supplies        Supply[]
  messages        Message[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  
  // CRM Relations
  assignedClients Client[]         // Admin assigns clients to Trading Reps
  clientActivities ClientActivity[] // Logs created by this user
  tasks           Task[]           // Tasks assigned to this user
  documents       Document[]       // Proposals generated by this user

  lastActive      DateTime     @default(now())
  createdAt       DateTime     @default(now())
}

// UPGRADED: 360-Degree CRM Profile (B2B & B2C)
model Client {
  id              String     @id @default(cuid())
  type            ClientType @default(CORPORATE) // Differentiates B2B vs B2C
  
  // Shared Core Details
  name            String     // Primary Contact Person OR Individual's Full Name
  email           String     @unique
  phone           String?
  address         String?
  country         String?    
  notes           String?
  
  // Corporate-Specific Fields
  company         String?    // Optional: Only used if type is CORPORATE
  registrationNo  String?    // Tax/VAT or Corporate ID
  website         String?
  
  // KYC & Compliance Engine
  kycStatus       KycStatus  @default(PENDING)
  tradeLicenseUrl String?    // Supabase link to trade license
  passportUrl     String?    // Supabase link to signatory passport

  // Team Assignment
  assignedRepId   String?
  assignedRep     User?      @relation(fields: [assignedRepId], references: [id])

  // CRM Relations
  activities      ClientActivity[]
  tasks           Task[]
  documents       Document[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// NEW: CRM Interactive Timeline
model ClientActivity {
  id          String   @id @default(cuid())
  type        String   // e.g., "EMAIL_SENT", "CALL", "NOTE", "DOCUMENT_GENERATED"
  description String
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}

// NEW: CRM Task & Follow-up Manager
model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime
  status       TaskStatus @default(PENDING)
  
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  assignedToId String
  assignedTo   User       @relation(fields: [assignedToId], references: [id])
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// NEW: Document Generation Engine Storage
model Document {
  id            String       @id @default(cuid())
  title         String
  type          DocumentType
  fileUrl       String       // Supabase URL to the generated PDF
  
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  generatedById String
  generatedBy   User         @relation(fields: [generatedById], references: [id])

  // Links to specific deals the document was generated for
  demandId      String?
  demand        Demand?      @relation(fields: [demandId], references: [id])
  
  supplyId      String?
  supply        Supply?      @relation(fields: [supplyId], references: [id])

  createdAt     DateTime     @default(now())
}

// ==============================
// 2. INTERNAL MARKETPLACE 
// ==============================
model Demand {
  id            String     @id @default(cuid())
  title         String
  quantity      Float      // CHANGED: Float to allow decimals (e.g. 25.5 MT)
  quantityUnit  String     @default("MT") // NEW: Unit of measurement
  tolerance     String?    // NEW: e.g., "+/- 10% Vessel Option"
  targetPrice   Float?     // CHANGED: Optional Price
  timeline      String
  
  // STRICT BUSINESS COLUMNS
  origin        String?
  destination   String?
  incoterms     String?
  paymentTerms  String?
  inspection    String?
  packaging     String?
  insurance     String?    // NEW: Insurance
  loadPort      String?    // NEW: Load Port

  // DYNAMIC COMMODITY SPECS
  keyTerms      Json?      

  specs         String     
  attachments   String[]   
  status        DealStatus @default(ACTIVE)

  creatorId     String
  createdBy     User       @relation(fields: [creatorId], references: [id])
  
  chatRoom      ChatRoom?  
  documents     Document[] // Proposals linked to this Demand

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Supply {
  id            String     @id @default(cuid())
  title         String
  quantity      Float      // CHANGED: Float to allow decimals (e.g. 25.5 MT)
  quantityUnit  String     @default("MT") // NEW: Unit of measurement
  tolerance     String?    // NEW: e.g., "+/- 10% Seller Option"
  price         Float?     // CHANGED: Optional Price
  location      String
  
  // STRICT BUSINESS COLUMNS
  origin        String?
  destination   String?
  incoterms     String?
  paymentTerms  String?
  inspection    String?
  packaging     String?
  insurance     String?    // NEW: Insurance
  loadPort      String?    // NEW: Load Port
  validityDate  DateTime?  

  // DYNAMIC COMMODITY SPECS
  keyTerms      Json?      

  specs         String
  attachments   String[]   
  status        DealStatus @default(ACTIVE)

  creatorId     String
  createdBy     User       @relation(fields: [creatorId], references: [id])

  chatRoom      ChatRoom?
  documents     Document[] // Proposals linked to this Supply

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ==============================
// 3. COLLABORATION ENGINE
// ==============================
model ChatRoom {
  id            String    @id @default(cuid())
  
  demandId      String?   @unique
  demand        Demand?   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  
  supplyId      String?   @unique
  supply        Supply?   @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  messages      Message[]
  createdAt     DateTime  @default(now())
}

model Message {
  id            String   @id @default(cuid())
  content       String
  attachments   String[] 
  mentions      String[] 

  senderId      String
  sender        User     @relation(fields: [senderId], references: [id])

  chatRoomId    String
  chatRoom      ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
}

// ==============================
// 4. GOVERNANCE & AUDIT
// ==============================
model AuditLog {
  id            String   @id @default(cuid())
  action        String   
  details       String   
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   
  message   String
  link      String?  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}