generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// ENUMS (ROLES, STATUSES, CRM)
// ==============================
enum Role {
  BUYER_REP
  SUPPLIER_REP
  TRADING_REP
  ADMIN
  MANAGEMENT
}

enum OnlineStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum DealStatus {
  DRAFT
  ACTIVE
  UNDER_NEGOTIATION
  SENT_TO_BUYER
  CLOSED_WON
  CLOSED_LOST
  CANCELLED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum DocumentType {
  SCO        // Soft Corporate Offer
  FCO        // Full Corporate Offer
  LOI        // Letter of Interest
  CONTRACT
  OTHER
}

enum ClientType {
  CORPORATE
  INDIVIDUAL
}

// ==============================
// 1. USER & CRM MODELS
// ==============================
model User {
  id              String       @id @default(cuid())
  firstName       String
  lastName        String
  email           String       @unique
  password        String       
  role            Role         @default(BUYER_REP)
  
  // Enterprise User Management & Permissions
  isActive        Boolean      @default(true) // Admins can toggle to suspend accounts
  canAddDeals     Boolean      @default(true) // Restrict who can post to the board
  canEditDeals    Boolean      @default(true) // Restrict who can modify existing deals
  canNegotiate    Boolean      @default(true) // Restrict access to Deal Desk Chat Rooms

  onlineStatus    OnlineStatus @default(OFFLINE)
  lastSeen        DateTime     @default(now())
  
  letterheadUrl   String?      // Vercel Blob URL for official document header

  // Relations
  demands         Demand[]
  supplies        Supply[]
  messages        Message[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  
  // CRM Relations
  assignedClients Client[]         
  clientActivities ClientActivity[] 
  tasks           Task[]           
  documents       Document[]       

  lastActive      DateTime     @default(now())
  createdAt       DateTime     @default(now())
}

model Client {
  id              String     @id @default(cuid())
  type            ClientType @default(CORPORATE) 
  
  name            String     
  email           String     @unique
  phone           String?
  address         String?
  country         String?    
  notes           String?
  
  company         String?    
  registrationNo  String?    
  website         String?
  
  kycStatus       KycStatus  @default(PENDING)
  tradeLicenseUrl String?    
  passportUrl     String?    

  assignedRepId   String?
  assignedRep     User?      @relation(fields: [assignedRepId], references: [id])

  activities      ClientActivity[]
  tasks           Task[]
  documents       Document[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model ClientActivity {
  id          String   @id @default(cuid())
  type        String   
  description String
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime
  status       TaskStatus @default(PENDING)
  
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  assignedToId String
  assignedTo   User       @relation(fields: [assignedToId], references: [id])
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Document {
  id            String       @id @default(cuid())
  title         String
  type          DocumentType
  fileUrl       String       
  
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  generatedById String
  generatedBy   User         @relation(fields: [generatedById], references: [id])

  demandId      String?
  demand        Demand?      @relation(fields: [demandId], references: [id])
  
  supplyId      String?
  supply        Supply?      @relation(fields: [supplyId], references: [id])

  createdAt     DateTime     @default(now())
}

// ==============================
// 2. INTERNAL MARKETPLACE 
// ==============================
model Demand {
  id            String     @id @default(cuid())
  title         String
  quantity      Float      
  quantityUnit  String     @default("MT") 
  tolerance     String?    
  targetPrice   Float?     
  timeline      String
  
  origin        String?
  destination   String?
  incoterms     String?
  paymentTerms  String?
  inspection    String?
  packaging     String?
  insurance     String?    
  loadPort      String?    

  keyTerms      Json?      

  specs         String     
  attachments   String[]   
  status        DealStatus @default(ACTIVE)

  creatorId     String
  createdBy     User       @relation(fields: [creatorId], references: [id])
  
  chatRoom      ChatRoom?  
  documents     Document[] 

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Supply {
  id            String     @id @default(cuid())
  title         String
  quantity      Float      
  quantityUnit  String     @default("MT") 
  tolerance     String?    
  price         Float?     
  location      String
  
  origin        String?
  destination   String?
  incoterms     String?
  paymentTerms  String?
  inspection    String?
  packaging     String?
  insurance     String?    
  loadPort      String?    
  validityDate  DateTime?  

  keyTerms      Json?      

  specs         String
  attachments   String[]   
  status        DealStatus @default(ACTIVE)

  creatorId     String
  createdBy     User       @relation(fields: [creatorId], references: [id])

  chatRoom      ChatRoom?
  documents     Document[] 

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ==============================
// 3. COLLABORATION ENGINE
// ==============================
model ChatRoom {
  id            String    @id @default(cuid())
  
  demandId      String?   @unique
  demand        Demand?   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  
  supplyId      String?   @unique
  supply        Supply?   @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  messages      Message[]
  createdAt     DateTime  @default(now())
}

model Message {
  id            String   @id @default(cuid())
  content       String
  attachments   String[] 
  mentions      String[] 

  senderId      String
  sender        User     @relation(fields: [senderId], references: [id])

  chatRoomId    String
  chatRoom      ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
}

// ==============================
// 4. GOVERNANCE & AUDIT
// ==============================
model AuditLog {
  id            String   @id @default(cuid())
  action        String   
  details       String   
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   
  message   String
  link      String?  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ==============================
// 5. SYSTEM CONFIGURATION
// ==============================
model SystemSettings {
  id              String   @id @default("global") // Enforce a single row
  companyName     String   @default("GlobCom International FZE")
  companyLogoUrl  String?  // Global sidebar logo
  updatedAt       DateTime @updatedAt
}